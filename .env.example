# ── FLUXION Backend Configuration ─────────────────────────────
# Copy this file to .env and fill in real values.
# cp .env.example .env

# PostgreSQL Connection (leave empty to fall back to SQLite)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fluxion

# Geoapify Places API (free tier: https://myprojects.geoapify.com)
GEOAPIFY_API_KEY=your_key_here

# JWT Authentication
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Simple API Key (for dev/staging — bypassed if JWT is present)
API_KEY=dev_key_for_testing
